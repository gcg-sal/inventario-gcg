// ──────────────────────────────────────────────
//  STATE
// ──────────────────────────────────────────────
let activeSection = 0;
// quantities[sectionId][rowIndex] = value string
const quantities = {};
SECTIONS.forEach(s => { quantities[s.id] = {}; });

// ──────────────────────────────────────────────
//  RENDER
// ──────────────────────────────────────────────
function init() {
  // Set date
  const now = new Date();
  document.getElementById('fechaHoy').textContent =
    now.toLocaleDateString('es-SV', { day: '2-digit', month: 'long', year: 'numeric' });

  buildNav();
  buildPanels();
  activateSection(0);
  updateProgress();
}

function buildNav() {
  const nav = document.getElementById('sectionNav');
  SECTIONS.forEach((sec, i) => {
    const btn = document.createElement('button');
    btn.className = 'nav-tab';
    btn.dataset.idx = i;
    btn.innerHTML = `${sec.icono} ${sec.nombre} <span class="badge" id="badge-${sec.id}">0/${sec.items.length}</span>`;
    btn.onclick = () => activateSection(i);
    nav.appendChild(btn);
  });
}

function buildPanels() {
  const main = document.getElementById('mainContent');
  SECTIONS.forEach((sec, si) => {
    const div = document.createElement('div');
    div.className = 'section-panel';
    div.id = `panel-${sec.id}`;

    if (sec.items.length === 0) {
      div.innerHTML = `
        <div class="section-header">
          <div class="section-icon">${sec.icono}</div>
          <div class="section-title">${sec.nombre}</div>
        </div>
        <div class="empty-section">
          <div class="emoji">📋</div>
          <p>Sin artículos asignados a esta área.</p>
          <p style="margin-top:8px;font-size:11px;color:var(--muted)">Si hay artículos, agréguelos manualmente en el Excel final.</p>
        </div>`;
    } else {
      let rows = '';
      sec.items.forEach((item, ri) => {
        rows += `
          <tr id="row-${sec.id}-${ri}">
            <td class="col-num">${ri+1}</td>
            <td class="col-codigo">${item[0]}</td>
            <td class="col-producto">${item[1]}</td>
            <td class="col-udm">${item[2]}</td>
            <td class="col-cantidad">
              <input type="number" inputmode="decimal" min="0" step="any"
                class="qty-input"
                id="qty-${sec.id}-${ri}"
                placeholder="—"
                onchange="handleQty('${sec.id}', ${ri}, this.value)"
                oninput="handleQty('${sec.id}', ${ri}, this.value)"
              >
            </td>
          </tr>`;
      });

      div.innerHTML = `
        <div class="section-header">
          <div class="section-icon">${sec.icono}</div>
          <div class="section-title">${sec.nombre}</div>
          <div class="section-count">${sec.items.length} artículos</div>
        </div>
        <table class="inv-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Código SAP</th>
              <th>Producto</th>
              <th>UDM</th>
              <th style="text-align:right">Cantidad</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>`;
    }
    main.appendChild(div);
  });
}

function activateSection(idx) {
  // Deactivate all
  document.querySelectorAll('.section-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(b => b.classList.remove('active'));
  // Activate selected
  const sec = SECTIONS[idx];
  document.getElementById(`panel-${sec.id}`).classList.add('active');
  document.querySelectorAll('.nav-tab')[idx].classList.add('active');
  activeSection = idx;
  // Scroll nav tab into view
  document.querySelectorAll('.nav-tab')[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
}

function handleQty(secId, rowIdx, val) {
  const input = document.getElementById(`qty-${secId}-${rowIdx}`);
  const row = document.getElementById(`row-${secId}-${rowIdx}`);
  if (val !== '' && val !== null && !isNaN(parseFloat(val))) {
    quantities[secId][rowIdx] = val;
    input.classList.add('has-value');
    row.classList.add('filled');
  } else {
    delete quantities[secId][rowIdx];
    input.classList.remove('has-value');
    row.classList.remove('filled');
  }
  updateProgress();
}

function countFilled(secId) {
  return Object.keys(quantities[secId]).length;
}

function updateProgress() {
  let total = 0, filled = 0;
  SECTIONS.forEach(sec => {
    total += sec.items.length;
    const f = countFilled(sec.id);
    filled += f;
    const badge = document.getElementById(`badge-${sec.id}`);
    if (badge) {
      badge.textContent = `${f}/${sec.items.length}`;
      const tab = badge.closest('.nav-tab');
      if (f > 0 && f === sec.items.length) tab.classList.add('done');
      else tab.classList.remove('done');
    }
  });
  const pct = total > 0 ? (filled / total * 100).toFixed(1) : 0;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = `${filled} / ${total}`;
  document.getElementById('footerFilled').textContent = filled;
}

// ──────────────────────────────────────────────
//  LIMPIAR SECCIÓN ACTUAL
// ──────────────────────────────────────────────
function limpiarSeccion() {
  const sec = SECTIONS[activeSection];
  if (!confirm(`¿Limpiar todos los campos de "${sec.nombre}"?`)) return;
  quantities[sec.id] = {};
  sec.items.forEach((_, ri) => {
    const input = document.getElementById(`qty-${sec.id}-${ri}`);
    const row = document.getElementById(`row-${sec.id}-${ri}`);
    if (input) { input.value = ''; input.classList.remove('has-value'); }
    if (row) row.classList.remove('filled');
  });
  updateProgress();
  showToast(`✓ ${sec.nombre} limpiada`);
}

// ──────────────────────────────────────────────
//  EXPORTAR EXCEL
// ──────────────────────────────────────────────
function exportarExcel() {
  const wb = XLSX.utils.book_new();
  const fecha = "10 DE MAYO 2026";

  // ── Hoja principal: INVENTARIO FISICO ──
  const wsData = [];
  wsData.push(["INVENTARIO " + fecha]);
  wsData.push(["CÓDIGO SAP", "", "", ""]);

  SECTIONS.forEach(sec => {
    if (sec.items.length === 0 && sec.id !== 'congelador') return;

    wsData.push([]); // blank row
    wsData.push([sec.icono + " " + sec.nombre.toUpperCase()]);
    wsData.push(["CODIGO", "PRODUCTO", "CANTIDAD FISICA", "UDM"]);

    if (sec.items.length === 0) {
      wsData.push(["", "(Sin artículos registrados)", "", ""]);
    } else {
      sec.items.forEach((item, ri) => {
        const qty = quantities[sec.id][ri];
        const qtyVal = (qty !== undefined && qty !== '') ? parseFloat(qty) : '';
        wsData.push([item[0], item[1], qtyVal, item[2]]);
      });
    }
  });

  const ws = XLSX.utils.aoa_to_sheet(wsData);

  // Column widths
  ws['!cols'] = [
    { wch: 15 }, { wch: 45 }, { wch: 18 }, { wch: 8 }
  ];

  XLSX.utils.book_append_sheet(wb, ws, "INVENTARIO FISICO");

  // ── Hoja resumen: INVENTARIO FISICO + RESERVA ──
  const wsResData = [["CODIGO", "PRODUCTO", "CANTIDAD FISICA", "UDM", "SECCIÓN"]];
  SECTIONS.forEach(sec => {
    sec.items.forEach((item, ri) => {
      const qty = quantities[sec.id][ri];
      if (qty !== undefined && qty !== '') {
        wsResData.push([item[0], item[1], parseFloat(qty), item[2], sec.nombre]);
      }
    });
  });

  const wsRes = XLSX.utils.aoa_to_sheet(wsResData);
  wsRes['!cols'] = [{ wch: 15 }, { wch: 45 }, { wch: 18 }, { wch: 8 }, { wch: 20 }];
  XLSX.utils.book_append_sheet(wb, wsRes, "INVENTARIO FISICO + RESERVA");

  // ── Filename ──
  const ts = new Date().toISOString().slice(0,10);
  XLSX.writeFile(wb, `INVENTARIO_GCG_${ts}.xlsx`);
  showToast('✓ Excel generado y descargado');
}

// ──────────────────────────────────────────────
//  TOAST
// ──────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

