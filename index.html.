  :root {
    --navy: #0D1B3E;
    --teal: #1C4656;
    --gold: #C9A84C;
    --gold-light: #E8C96E;
    --bg: #F4F1EA;
    --surface: #FDFBF7;
    --border: #D8D0C0;
    --text: #1A1A2E;
    --muted: #7A7060;
    --green: #2D7A4F;
    --red: #8B1A1A;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Mono', monospace;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* ── HEADER ── */
  header {
    background: var(--navy);
    color: white;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 16px rgba(0,0,0,0.4);
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    border-bottom: 2px solid var(--gold);
  }

  .header-brand {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .header-brand .co { 
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 18px;
    color: var(--gold);
    letter-spacing: 0.05em;
  }

  .header-brand .sub {
    font-size: 10px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .header-date {
    text-align: right;
    font-size: 11px;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.08em;
  }

  .header-date strong {
    display: block;
    color: var(--gold-light);
    font-size: 13px;
    font-weight: 500;
  }

  /* ── PROGRESS BAR ── */
  .progress-wrap {
    padding: 8px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(0,0,0,0.2);
  }

  .progress-bar-bg {
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.15);
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 3px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .progress-label {
    font-size: 11px;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
    min-width: 70px;
    text-align: right;
  }

  /* ── NAV TABS ── */
  .section-nav {
    display: flex;
    overflow-x: auto;
    background: var(--teal);
    scrollbar-width: none;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .section-nav::-webkit-scrollbar { display: none; }

  .nav-tab {
    padding: 9px 16px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    color: rgba(255,255,255,0.6);
    border: none;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.2s;
    position: relative;
  }

  .nav-tab.active {
    color: var(--gold-light);
    border-bottom-color: var(--gold);
  }

  .nav-tab .badge {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    border-radius: 10px;
    font-size: 9px;
    padding: 1px 5px;
    margin-left: 4px;
    font-weight: 600;
    vertical-align: middle;
  }

  .nav-tab.done .badge { background: var(--green); color: white; }

  /* ── MAIN CONTENT ── */
  main { padding-bottom: 120px; }

  .section-panel {
    display: none;
    padding: 16px;
  }
  .section-panel.active { display: block; }

  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--gold);
  }

  .section-icon {
    width: 36px;
    height: 36px;
    background: var(--navy);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: var(--navy);
    letter-spacing: 0.02em;
  }

  .section-count {
    margin-left: auto;
    font-size: 11px;
    color: var(--muted);
    background: var(--border);
    padding: 2px 8px;
    border-radius: 10px;
  }

  /* ── TABLE ── */
  .inv-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 8px rgba(0,0,0,0.08);
  }

  .inv-table thead th {
    background: var(--navy);
    color: rgba(255,255,255,0.7);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 8px 10px;
    text-align: left;
  }

  .inv-table thead th:last-child { text-align: center; }

  .inv-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .inv-table tbody tr:last-child { border-bottom: none; }
  .inv-table tbody tr:hover { background: #F0EDE5; }
  .inv-table tbody tr.filled { background: #EDF7F1; }
  .inv-table tbody tr.filled:hover { background: #E0F2E8; }

  .col-codigo {
    padding: 10px 10px;
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
    width: 110px;
  }

  .col-producto {
    padding: 10px 8px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
  }

  .col-udm {
    padding: 10px 6px;
    font-size: 10px;
    color: var(--teal);
    font-weight: 600;
    width: 40px;
    text-align: center;
  }

  .col-cantidad {
    padding: 6px 10px;
    width: 110px;
  }

  .qty-input {
    width: 100%;
    padding: 7px 8px;
    border: 2px solid var(--border);
    border-radius: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    text-align: right;
    background: white;
    color: var(--text);
    transition: border-color 0.2s, background 0.2s;
    -webkit-appearance: none;
  }

  .qty-input:focus {
    outline: none;
    border-color: var(--gold);
    background: #FFFDF5;
  }

  .qty-input.has-value {
    border-color: var(--green);
    background: #F0FFF7;
    color: var(--green);
  }

  /* Row number */
  .col-num {
    padding: 10px 8px 10px 12px;
    font-size: 10px;
    color: var(--border);
    width: 30px;
    text-align: right;
    font-weight: 500;
  }

  /* ── FIXED FOOTER ── */
  footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--navy);
    border-top: 2px solid var(--gold);
    padding: 12px 20px;
    display: flex;
    gap: 10px;
    align-items: center;
    z-index: 200;
  }

  .btn-export {
    flex: 1;
    background: var(--gold);
    color: var(--navy);
    border: none;
    border-radius: 10px;
    padding: 14px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .btn-export:hover { background: var(--gold-light); transform: translateY(-1px); }
  .btn-export:active { transform: translateY(0); }

  .btn-clear {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    padding: 14px 16px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-clear:hover { background: rgba(255,255,255,0.15); }

  .footer-stats {
    text-align: center;
    font-size: 10px;
    color: rgba(255,255,255,0.5);
    line-height: 1.3;
  }
  .footer-stats strong { color: var(--gold-light); font-size: 12px; display: block; }

  /* ── TOAST ── */
  .toast {
    position: fixed;
    top: 80px;
    left: 50%;
    transform: translateX(-50%) translateY(-20px);
    background: var(--green);
    color: white;
    padding: 10px 20px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s;
    z-index: 999;
    white-space: nowrap;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ── EMPTY STATE ── */
  .empty-section {
    text-align: center;
    padding: 40px 20px;
    color: var(--muted);
    font-size: 13px;
  }
  .empty-section .emoji { font-size: 36px; margin-bottom: 10px; }

</style>
</head>
